{
  "name": "bookmarks-db",
  "version": "1.1.0",
  "description": "Fast bookmarks search with keyboard navigation",
  "type": "module",
  "scripts": {
    "lint": "eslint . && (stylelint \"**/*.css\" --allow-empty-input || true)",
    "lint:fix": "eslint . --fix && stylelint \"**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "lint:style": "stylelint \"**/*.css\""
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "knip": "^5.0.0",
    "prettier": "^3.2.0",
    "stylelint": "^17.11.1",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
